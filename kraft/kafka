  echo -e "${BOLD}kafka${RESET} — Kafka cluster management CLI"
  echo ""
  echo -e "${BOLD}USAGE${RESET}"
  echo "  kafka <command> [options]"
  echo ""
  echo -e "${BOLD}COMMANDS${RESET}"
  printf "  %-30s %s\n" "install"              "First-time setup: load images, configure, start"
  printf "  %-30s %s\n" "start"                "Start all services"
  printf "  %-30s %s\n" "stop"                 "Stop all services (data preserved)"
  printf "  %-30s %s\n" "restart [service]"    "Restart all or a specific service"
  printf "  %-30s %s\n" "down"                 "Remove containers (volumes preserved)"
  printf "  %-30s %s\n" "status"               "Show running service state"
  printf "  %-30s %s\n" "logs [-f] [service]"  "Show logs; -f to follow"
  printf "  %-30s %s\n" "health"               "Detailed health check of all services"
  printf "  %-30s %s\n" "lag"                  "Summary of all consumer group lag"
  printf "  %-30s %s\n" "lag <group>"          "Per-partition lag for a specific group"
  printf "  %-30s %s\n" "lag --topic <topic>"  "Lag filtered to a specific topic"
  printf "  %-30s %s\n" "ui"                   "Show Kafbat UI URL and credentials"
  printf "  %-30s %s\n" "config"               "Show current .env config"
  printf "  %-30s %s\n" "config set KEY=VAL"   "Set a config value in .env"
  printf "  %-30s %s\n" "load-images"          "Load Docker images from images/ without starting"
  printf "  %-30s %s\n" "uninstall"            "Remove containers (volumes kept)"
  printf "  %-30s %s\n" "uninstall --purge"    "Remove containers AND delete all data"
  printf "  %-30s %s\n" "doctor"               "Preflight checks (ports, firewalld, Docker) before install"
